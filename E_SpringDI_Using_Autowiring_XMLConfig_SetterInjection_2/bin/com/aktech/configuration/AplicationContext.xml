<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

	<bean class="com.aktech.bean.Address" id="addr1">
	<property name="houseNo" value="112"></property>
	<property name="city" value="Amravti"></property>
	<property name="pinCode" value="444404"></property>
	</bean>
	
	<bean class="com.aktech.bean.Address" id="addr2" autowire-candidate="false">
	<property name="houseNo" value="212"></property>
	<property name="city" value="Akola"></property>
	<property name="pinCode" value="274071"></property>
	</bean>
	
	
    <bean class="com.aktech.bean.Student" id="std" autowire="byType">
    <property name="name" value="Akshay"></property>
    <property name="rollno" value="101"></property>
    
    </bean>

</beans>
